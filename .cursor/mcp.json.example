{
  "mcpServers": {
    "zmailr-local": {
      "_comment": "Local monorepo dev — build first: pnpm --filter @zmailr/mcp run build",
      "command": "node",
      "args": ["packages/mcp/dist/index.js"],
      "env": {
        "ZMAILR_BASE_URL": "https://zmailr.itool.eu.cc",
        "ZMAILR_TOKEN": "your-bearer-token"
      }
    },
    "zmailr-npx": {
      "_comment": "After npm publish — use npx @zmailr/mcp (rename key to zmailr if you only need one)",
      "command": "npx",
      "args": ["-y", "@zmailr/mcp"],
      "env": {
        "ZMAILR_BASE_URL": "https://zmailr.itool.eu.cc",
        "ZMAILR_TOKEN": "your-bearer-token"
      }
    }
  }
}
