{
  "name": "zmailr",
  "version": "1.0.0",
  "description": "zMailR - Enhanced fork of zaunist/zmail, 24-hour temporary email service",
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.js",
    "dev:frontend": "pnpm --filter frontend run dev",
    "dev:backend": "wrangler dev",
    "dev:docs": "pnpm --filter @zmail/docs-site run dev",
    "build": "tsx scripts/generate-openapi.ts && pnpm --filter @zmail/docs-site run build && pnpm --filter frontend run build && node scripts/finalize-docs-build.mjs",
    "test": "pnpm --filter @zmail/worker run test",
    "deploy": "wrangler deploy"
  },
  "keywords": [],
  "author": "",
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "tsx": "^4.19.3",
    "vitepress": "^1.6.3",
    "vue": "^3.5.13",
    "wrangler": "^4.20.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jia0327/zmailr.git"
  }
}
